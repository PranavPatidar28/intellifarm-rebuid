# Shared
NODE_ENV=development
APP_URL=http://localhost:3000
APP_URLS=http://localhost:3000,http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intellifarm?schema=public

# Auth
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-second-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
DEV_OTP_CODE=123456

# Weather
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_HISTORICAL_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# Predictions
PREDICTION_PROVIDER_MODE=mock
PREDICTION_PROVIDER_URL=
PREDICTION_PROVIDER_API_KEY=
# Set PREDICTION_PROVIDER_MODE=railway for the live /predict API adapter.

# Disease analysis
DISEASE_PROVIDER_MODE=live
DISEASE_PROVIDER_URL=https://crop-disease-detection-api-338815576551.asia-south1.run.app
DISEASE_PROVIDER_API_KEY=

# Assistant chat
GEMINI_CHAT_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=replace-with-your-key

# Markets
MARKET_PROVIDER_MODE=seeded
DATA_GOV_MARKET_BASE_URL=https://api.data.gov.in/resource
DATA_GOV_API_KEY=
DATA_GOV_RESOURCE_ID=

# Storage
UPLOAD_DIR=apps/api/uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:4000/uploads
