generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PreferredLanguage {
  en
  hi
}

enum UserRole {
  FARMER
  ADMIN
}

enum IrrigationType {
  RAIN_FED
  DRIP
  SPRINKLER
  FLOOD
  MANUAL
}

enum SoilType {
  ALLUVIAL
  BLACK_REGUR
  RED
  LATERITE
  SANDY
  CLAY_HEAVY
  LOAMY_MIXED
  NOT_SURE
}

enum CropSeasonStatus {
  PLANNED
  ACTIVE
  HARVESTED
  ARCHIVED
}

enum TaskType {
  IRRIGATION
  FERTILIZER
  SCOUTING
  HARVEST_PREP
  GENERAL
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  COMPLETED
  SKIPPED
  OVERDUE
}

enum AlertType {
  WEATHER
  TASK
  DISEASE
  SYSTEM
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DiseaseReportStatus {
  PENDING
  ANALYZED
  ESCALATED
}

enum FacilityType {
  MANDI
  WAREHOUSE
}

enum PredictionType {
  CROP_SUGGESTION
  RESOURCE_ESTIMATE
}

enum PredictionStatus {
  COMPLETED
  FAILED
}

enum AssistantMessageRole {
  USER
  ASSISTANT
}

enum DiseaseCaptureMode {
  STANDARD
  CAMERA_DUAL_ANGLE
}

enum DiseaseAnalysisSource {
  MOCK_PROVIDER
  LIVE_PROVIDER
}

model User {
  id                String              @id @default(uuid())
  name              String?
  phone             String              @unique
  preferredLanguage PreferredLanguage   @default(en)
  state             String?
  district          String?
  village           String?
  profilePhotoUrl   String?
  role              UserRole            @default(FARMER)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  alerts            Alert[]
  sessions          AuthSession[]
  farmPlots         FarmPlot[]
  assistantThreads  AssistantThread[]
  predictionRuns    PredictionRun[]
}

model OtpChallenge {
  id           String    @id @default(uuid())
  phone        String
  otpHash      String
  expiresAt    DateTime
  attemptCount Int       @default(0)
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([phone, createdAt(sort: Desc)])
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  deviceType       String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model FarmPlot {
  id             String            @id @default(uuid())
  userId         String
  name           String
  state          String
  district       String
  village        String
  area           Float
  latitude       Float?
  longitude      Float?
  irrigationType IrrigationType
  soilType       SoilType?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  cropSeasons    CropSeason[]
  weatherShots   WeatherSnapshot[]
  predictionRuns PredictionRun[]

  @@index([userId, createdAt])
}

model CropDefinition {
  id           String          @id @default(uuid())
  slug         String          @unique
  nameEn       String
  nameHi       String
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  cropSeasons  CropSeason[]
  stageRules   CropStageRule[]
  taskTemplates TaskTemplate[]
}

model CropSeason {
  id               String            @id @default(uuid())
  farmPlotId       String
  cropDefinitionId String
  cropName         String
  sowingDate       DateTime          @db.Date
  currentStage     String
  status           CropSeasonStatus
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  alerts           Alert[]
  diseaseReports   DiseaseReport[]
  predictionRuns   PredictionRun[]
  tasks            CropTask[]
  cropDefinition   CropDefinition    @relation(fields: [cropDefinitionId], references: [id], onDelete: Restrict)
  farmPlot         FarmPlot          @relation(fields: [farmPlotId], references: [id], onDelete: Cascade)

  @@index([farmPlotId, status])
}

model CropStageRule {
  id               String         @id @default(uuid())
  cropDefinitionId String
  stageKey         String
  labelEn          String
  labelHi          String
  startDay         Int
  endDay           Int
  sortOrder        Int
  cropDefinition   CropDefinition @relation(fields: [cropDefinitionId], references: [id], onDelete: Cascade)

  @@unique([cropDefinitionId, stageKey])
  @@index([cropDefinitionId, sortOrder])
}

model TaskTemplate {
  id               String         @id @default(uuid())
  cropDefinitionId String
  stageKey         String
  titleEn          String
  titleHi          String
  descriptionEn    String
  descriptionHi    String
  dueDayOffset     Int
  taskType         TaskType
  priority         TaskPriority
  weatherCondition Json?
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cropTasks        CropTask[]
  cropDefinition   CropDefinition @relation(fields: [cropDefinitionId], references: [id], onDelete: Cascade)

  @@index([cropDefinitionId, stageKey, dueDayOffset])
}

model CropTask {
  id            String       @id @default(uuid())
  cropSeasonId  String
  taskTemplateId String
  title         String
  description   String
  dueDate       DateTime     @db.Date
  taskType      TaskType
  priority      TaskPriority
  status        TaskStatus   @default(PENDING)
  generatedBy   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  cropSeason    CropSeason   @relation(fields: [cropSeasonId], references: [id], onDelete: Cascade)
  taskTemplate  TaskTemplate @relation(fields: [taskTemplateId], references: [id], onDelete: Cascade)

  @@unique([cropSeasonId, taskTemplateId, dueDate])
  @@index([cropSeasonId, dueDate, status])
}

model WeatherSnapshot {
  id           String   @id @default(uuid())
  farmPlotId   String
  source       String
  forecastDate DateTime
  summary      String
  rawPayload   Json
  createdAt    DateTime @default(now())
  farmPlot     FarmPlot @relation(fields: [farmPlotId], references: [id], onDelete: Cascade)

  @@index([farmPlotId, forecastDate])
}

model DiseaseReport {
  id                 String              @id @default(uuid())
  cropSeasonId       String
  image1Url          String?
  image2Url          String?
  voiceNoteUrl       String?
  userNote           String?
  predictedIssue     String?
  confidenceScore    Float               @default(0)
  recommendation     String
  escalationRequired Boolean             @default(false)
  status             DiseaseReportStatus @default(PENDING)
  provider           String              @default("mock")
  providerRef        String?
  captureMode        DiseaseCaptureMode  @default(STANDARD)
  analysisSource     DiseaseAnalysisSource @default(MOCK_PROVIDER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cropSeason         CropSeason          @relation(fields: [cropSeasonId], references: [id], onDelete: Cascade)

  @@index([cropSeasonId, createdAt(sort: Desc)])
}

model MarketRecord {
  id         String   @id @default(uuid())
  facilityId String?
  cropName   String
  mandiName  String
  district   String
  state      String
  priceMin   Float
  priceMax   Float
  priceModal Float
  recordDate DateTime @db.Date
  source     String
  createdAt  DateTime @default(now())
  facility   Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  @@index([cropName, state, district, recordDate(sort: Desc)])
  @@index([facilityId, recordDate(sort: Desc)])
}

model Scheme {
  id              String            @id @default(uuid())
  title           String
  titleHi         String?
  description     String
  descriptionHi   String?
  category        String
  applicableState String
  officialLink    String
  language        PreferredLanguage @default(en)
  relatedCrops    String[]          @default([])
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([applicableState, category, active])
}

model Alert {
  id           String     @id @default(uuid())
  userId       String
  cropSeasonId String
  title        String
  message      String
  alertType    AlertType
  severity     Severity
  isRead       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  cropSeason   CropSeason @relation(fields: [cropSeasonId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([cropSeasonId, alertType])
}

model Facility {
  id          String       @id @default(uuid())
  type        FacilityType
  name        String
  state       String
  district    String
  village     String?
  latitude    Float
  longitude   Float
  services    String[]     @default([])
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  marketRecords MarketRecord[]

  @@index([type, state, district, active])
}

model PredictionRun {
  id          String           @id @default(uuid())
  userId      String
  farmPlotId  String?
  cropSeasonId String?
  type        PredictionType
  inputJson   Json
  outputJson  Json
  provider    String
  status      PredictionStatus
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmPlot    FarmPlot?        @relation(fields: [farmPlotId], references: [id], onDelete: SetNull)
  cropSeason  CropSeason?      @relation(fields: [cropSeasonId], references: [id], onDelete: SetNull)

  @@index([userId, type, createdAt(sort: Desc)])
  @@index([farmPlotId, createdAt(sort: Desc)])
  @@index([cropSeasonId, createdAt(sort: Desc)])
}

model AssistantThread {
  id          String             @id @default(uuid())
  userId      String
  title       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AssistantMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model AssistantMessage {
  id          String               @id @default(uuid())
  threadId    String
  role        AssistantMessageRole
  content     String
  sources     Json?
  safetyFlags Json?
  createdAt   DateTime             @default(now())
  thread      AssistantThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
